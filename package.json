{
	"name": "@geoterritories/n8n-nodes-geoterritories",
	"version": "0.1.2",
	"description": "Native n8n node to add Geo territories for your n8n automations.",
	"license": "MIT",
	"homepage": "https://geoterritories.com",
	"keywords": [
		"n8n-community-node-package",
		"geoterritories",
		"geo fence"
	],
	"author": {
		"name": "Geo territories",
		"email": "shamika@mail.loomilab.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/geoterritories/n8n-node-geoterritories.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:local": "n8n-node build && docker-compose -f ../self-hosted-ai-starter-kit/docker-compose.yml restart n8n",
		"dev": "docker-compose -f ../self-hosted-ai-starter-kit/docker-compose.yml --profile cpu up -d",
		"build:watch": "tsc --watch",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/GeoTerritoriesOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/GeoTerritories/GeoTerritories.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}